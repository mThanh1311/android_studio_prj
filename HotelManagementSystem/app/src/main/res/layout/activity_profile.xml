<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB">

    <ScrollView
        android:id="@+id/scrollProfile"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="105dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="290dp"
                android:background="@drawable/bg_home_header_blue"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="54dp"
                android:paddingEnd="24dp"
                android:paddingBottom="24dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgProfileAvatar"
                    android:layout_width="108dp"
                    android:layout_height="108dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/avatar_male"
                    app:shapeAppearanceOverlay="@style/CircleImage"
                    app:strokeColor="#FFFFFF"
                    app:strokeWidth="3dp" />

                <TextView
                    android:id="@+id/tvProfileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Thanh"
                    android:textColor="#FFFFFF"
                    android:textSize="23sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvProfileEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:text="thanh123@gmail.com"
                    android:textColor="#EAF6FF"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvProfileGreeting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:text="Chúc bạn có một kỳ nghỉ thật tuyệt vời."
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- MEMBER TIERS SLIDER -->
            <HorizontalScrollView
                android:id="@+id/hsvMemberTiers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="18dp"
                android:layout_marginEnd="20dp"
                android:overScrollMode="never"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- SILVER -->
                    <LinearLayout
                        android:id="@+id/cardTierSilver"
                        android:layout_width="260dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_member_card_inactive"
                        android:elevation="2dp"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Silver"
                            android:textColor="#6B7280"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="0 - 999 points"
                            android:textColor="#94A3B8"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:lineSpacingExtra="3dp"
                            android:text="Khởi đầu hành trình thành viên với các ưu đãi cơ bản."
                            android:textColor="#6B7280"
                            android:textSize="15sp" />

                    </LinearLayout>

                    <!-- GOLD -->
                    <LinearLayout
                        android:id="@+id/cardTierGold"
                        android:layout_width="260dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_member_card_inactive"
                        android:elevation="2dp"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gold"
                            android:textColor="#9A673A"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="1,000 - 2,999 points"
                            android:textColor="#94A3B8"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:lineSpacingExtra="3dp"
                            android:text="Ưu đãi tốt hơn, tích điểm nhanh hơn và hỗ trợ ưu tiên."
                            android:textColor="#6B7280"
                            android:textSize="15sp" />

                    </LinearLayout>

                    <!-- PLATINUM -->
                    <LinearLayout
                        android:id="@+id/cardTierPlatinum"
                        android:layout_width="260dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="12dp"
                        android:background="@drawable/bg_member_card_inactive"
                        android:elevation="2dp"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Platinum"
                            android:textColor="#475569"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="3,000 - 5,999 points"
                            android:textColor="#94A3B8"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:lineSpacingExtra="3dp"
                            android:text="Đặc quyền nổi bật hơn, check-in nhanh và nhiều quyền lợi hơn."
                            android:textColor="#6B7280"
                            android:textSize="15sp" />

                    </LinearLayout>

                    <!-- DIAMOND -->
                    <LinearLayout
                        android:id="@+id/cardTierDiamond"
                        android:layout_width="260dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_member_card_inactive"
                        android:elevation="2dp"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Diamond"
                            android:textColor="#2563EB"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="6,000+ points"
                            android:textColor="#94A3B8"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:lineSpacingExtra="3dp"
                            android:text="Hạng cao nhất với đầy đủ đặc quyền cao cấp tại ABC Hotel."
                            android:textColor="#6B7280"
                            android:textSize="15sp" />

                    </LinearLayout>

                </LinearLayout>

            </HorizontalScrollView>

            <!-- POINTS / PROGRESS CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/bg_home_card"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvMembershipLevel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Gold"
                        android:textColor="#9A673A"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvMembershipPoints"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_chip_gold"
                        android:paddingStart="14dp"
                        android:paddingTop="8dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="8dp"
                        android:text="1.250 points"
                        android:textColor="#9A673A"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvMembershipDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:lineSpacingExtra="3dp"
                    android:text="Ưu đãi tốt hơn, tích điểm nhanh hơn và hỗ trợ ưu tiên."
                    android:textColor="#6B7280"
                    android:textSize="15sp" />

                <ProgressBar
                    android:id="@+id/progressMembership"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="18dp"
                    android:max="100"
                    android:progress="40"
                    android:progressDrawable="@drawable/bg_progress_blue" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvCurrentTierLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Gold"
                        android:textColor="#9CA3AF"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvNextTierLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Platinum"
                        android:textColor="#9CA3AF"
                        android:textSize="14sp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tvNextTierHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Còn 1.750 điểm để lên Platinum"
                    android:textColor="#2563EB"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- CONTENT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="24dp">

                <!-- STATS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_home_card"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvProfileTotalBooking"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#21A8F3"
                            android:textSize="27sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="Booking"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_home_card"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tvProfileActiveBooking"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#16A34A"
                            android:textSize="27sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:text="Đang đặt"
                            android:textColor="#6B7280"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- MEMBER INFO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_home_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Quyền lợi của bạn"
                        android:textColor="#111827"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:lineSpacingExtra="5dp"
                        android:text="• Giảm 10% khi đặt phòng&#10;• Tích điểm sau mỗi booking&#10;• Hỗ trợ check-in nhanh&#10;• Nhận thông báo ưu đãi sớm&#10;• Hỗ trợ khách hàng ưu tiên"
                        android:textColor="#6B7280"
                        android:textSize="14sp" />

                </LinearLayout>

                <!-- RECENT BOOKING -->
                <LinearLayout
                    android:id="@+id/cardRecentBooking"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_home_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Booking gần đây"
                        android:textColor="#111827"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvRecentBookingInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:lineSpacingExtra="4dp"
                        android:text="Chưa có booking gần đây."
                        android:textColor="#6B7280"
                        android:textSize="14sp" />

                </LinearLayout>

                <!-- ACTION BUTTONS -->
                <Button
                    android:id="@+id/btnMyBookings"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="22dp"
                    android:background="@drawable/bg_button_primary"
                    android:backgroundTint="@null"
                    android:text="Xem booking của tôi"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnEnableFaceCheckin"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_button_primary"
                    android:backgroundTint="@null"
                    android:text="Kích hoạt Face Check-in"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnSettings"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_button_primary"
                    android:backgroundTint="@null"
                    android:text="Cài đặt tài khoản"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <include layout="@layout/layout_bottom_nav_user" />

</FrameLayout>