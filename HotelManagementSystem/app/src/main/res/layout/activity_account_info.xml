<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="135dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="175dp"
                android:background="@drawable/bg_home_header_blue"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="42dp"
                android:paddingEnd="24dp"
                android:paddingBottom="18dp">

                <TextView
                    android:id="@+id/btnBackAccount"
                    android:layout_width="44dp"
                    android:layout_height="34dp"
                    android:gravity="center_vertical"
                    android:text="←"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Thông tin tài khoản"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Quản lý hồ sơ cá nhân và bảo mật tài khoản."
                    android:textColor="#EAF6FF"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- CONTENT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingTop="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="32dp">


                <!-- PROFILE CARD -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="-26dp"
                    android:background="@drawable/bg_home_card"
                    android:elevation="3dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/imgAccountAvatar"
                        android:layout_width="82dp"
                        android:layout_height="82dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/avatar_male"
                        app:shapeAppearanceOverlay="@style/CircleImage"
                        app:strokeColor="#E5E7EB"
                        app:strokeWidth="2dp" />

                    <TextView
                        android:id="@+id/tvAccountNameHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Thanh"
                        android:textColor="#111827"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAccountEmailHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="thanh123@gmail.com"
                        android:textColor="#6B7280"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_chip_gold"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="Gold Member • 1.250 điểm"
                        android:textColor="#8B5E3C"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- PERSONAL INFO CARD -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_home_card"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Thông tin cá nhân"
                            android:textColor="#111827"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/btnEditInfo"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:background="@drawable/bg_chip_blue"
                            android:gravity="center"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:text="Chỉnh sửa"
                            android:textColor="#0D47A1"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- NAME -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="Họ tên"
                        android:textColor="#9CA3AF"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/edtAccountName"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_input"
                        android:enabled="false"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textColor="#111827"
                        android:textSize="14sp" />

                    <!-- EMAIL -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Email"
                        android:textColor="#9CA3AF"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/edtAccountEmail"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_input"
                        android:enabled="false"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textColor="#6B7280"
                        android:textSize="14sp" />

                    <!-- PHONE -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Số điện thoại"
                        android:textColor="#9CA3AF"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/edtAccountPhone"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_input"
                        android:enabled="false"
                        android:hint="Chưa cập nhật"
                        android:inputType="phone"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textColor="#111827"
                        android:textSize="14sp" />

                    <!-- DOB -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Ngày sinh"
                        android:textColor="#9CA3AF"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvAccountDob"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_input"
                        android:enabled="false"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="Chưa cập nhật"
                        android:textColor="#9CA3AF"
                        android:textSize="14sp" />

                    <!-- GENDER -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Giới tính"
                        android:textColor="#9CA3AF"
                        android:textSize="12sp" />

                    <RadioGroup
                        android:id="@+id/rgAccountGender"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:enabled="false"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rbAccountMale"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:buttonTint="#21A8F3"
                            android:enabled="false"
                            android:text="Nam"
                            android:textColor="#111827" />

                        <RadioButton
                            android:id="@+id/rbAccountFemale"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:buttonTint="#21A8F3"
                            android:enabled="false"
                            android:text="Nữ"
                            android:textColor="#111827" />

                    </RadioGroup>

                    <Button
                        android:id="@+id/btnSaveInfo"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_button_primary"
                        android:backgroundTint="@null"
                        android:text="Lưu thông tin"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                </LinearLayout>

                <!-- SECURITY CARD -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_home_card"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Bảo mật"
                        android:textColor="#111827"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Bạn có thể thay đổi mật khẩu để bảo vệ tài khoản."
                        android:textColor="#6B7280"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/btnChangePassword"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_button_primary"
                        android:backgroundTint="@null"
                        android:text="Đổi mật khẩu"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/layoutPasswordFields"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <EditText
                            android:id="@+id/edtOldPassword"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_input"
                            android:hint="Mật khẩu hiện tại"
                            android:inputType="textPassword"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:textSize="14sp" />

                        <EditText
                            android:id="@+id/edtNewPassword"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_input"
                            android:hint="Mật khẩu mới"
                            android:inputType="textPassword"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:textSize="14sp" />

                        <EditText
                            android:id="@+id/edtConfirmNewPassword"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="12dp"
                            android:background="@drawable/bg_input"
                            android:hint="Xác nhận mật khẩu mới"
                            android:inputType="textPassword"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:textSize="14sp" />

                        <Button
                            android:id="@+id/btnSavePassword"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="16dp"
                            android:background="@drawable/bg_button_primary"
                            android:backgroundTint="@null"
                            android:text="Lưu mật khẩu"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <include layout="@layout/layout_bottom_nav_user" />

</FrameLayout>