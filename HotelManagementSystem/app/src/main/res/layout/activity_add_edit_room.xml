<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F5F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Thông tin phòng"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            android:layout_marginBottom="18dp" />

        <EditText
            android:id="@+id/edtRoomName"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Tên phòng"
            android:background="@drawable/bg_input"
            android:padding="14dp" />

        <EditText
            android:id="@+id/edtRoomType"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Loại phòng"
            android:background="@drawable/bg_input"
            android:padding="14dp"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/edtPrice"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Giá phòng"
            android:inputType="number"
            android:background="@drawable/bg_input"
            android:padding="14dp"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/edtCapacity"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Sức chứa"
            android:inputType="number"
            android:background="@drawable/bg_input"
            android:padding="14dp"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/edtDescription"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:hint="Mô tả"
            android:gravity="top"
            android:background="@drawable/bg_input"
            android:padding="14dp"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/edtStatus"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="available / unavailable"
            android:background="@drawable/bg_input"
            android:padding="14dp"
            android:layout_marginTop="12dp" />

        <Button
            android:id="@+id/btnSaveRoom"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Lưu phòng"
            android:layout_marginTop="22dp" />

    </LinearLayout>

</ScrollView>