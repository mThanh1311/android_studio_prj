<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB">

    <ScrollView
        android:id="@+id/scrollBranchList"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="105dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="18dp">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="185dp"
                android:background="@drawable/bg_home_header_blue"
                android:orientation="vertical"
                android:paddingStart="22dp"
                android:paddingTop="52dp"
                android:paddingEnd="22dp"
                android:paddingBottom="18dp">

                <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="44dp"
                    android:layout_height="34dp"
                    android:gravity="center_vertical"
                    android:text="←"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Chi nhánh khách sạn"
                    android:textColor="#FFFFFF"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:lineSpacingExtra="3dp"
                    android:text="Khám phá các địa điểm lưu trú nổi bật của ABC Hotel."
                    android:textColor="#EAF6FF"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- CONTENT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp">

                <!-- BRANCH CITY -->
                <FrameLayout
                    android:id="@+id/cardBranchCity"
                    android:layout_width="match_parent"
                    android:layout_height="270dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_card_white_rounded"
                    android:clickable="true"
                    android:clipToOutline="true"
                    android:focusable="true"
                    android:outlineProvider="background">

                    <ImageView
                        android:id="@+id/imgBranchCity"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/branch_city" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_amenity_image_overlay" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="14dp"
                        android:background="@drawable/bg_chip_white_soft"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="Trung tâm"
                        android:textColor="#0F6CBD"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="ABC Hotel Trung tâm"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="12 Nguyễn Huệ, Quận 1, TP.HCM"
                            android:textColor="#F8FAFC"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:lineSpacingExtra="2dp"
                            android:text="Phù hợp cho khách công tác, du lịch thành phố và di chuyển nhanh đến các khu mua sắm."
                            android:textColor="#E5E7EB"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_chip_white_soft"
                            android:gravity="center"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="Gần trung tâm thương mại"
                            android:textColor="#0F6CBD"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </FrameLayout>

                <!-- BRANCH BEACH -->
                <FrameLayout
                    android:id="@+id/cardBranchBeach"
                    android:layout_width="match_parent"
                    android:layout_height="270dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_card_white_rounded"
                    android:clickable="true"
                    android:clipToOutline="true"
                    android:focusable="true"
                    android:outlineProvider="background">

                    <ImageView
                        android:id="@+id/imgBranchBeach"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/branch_beach" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_amenity_image_overlay" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="14dp"
                        android:background="@drawable/bg_chip_white_soft"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="Resort"
                        android:textColor="#0F6CBD"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Biển Xanh Resort"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="88 Trần Phú, Vũng Tàu"
                            android:textColor="#F8FAFC"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:lineSpacingExtra="2dp"
                            android:text="Không gian nghỉ dưỡng gần biển, phù hợp cho gia đình, cặp đôi và kỳ nghỉ cuối tuần."
                            android:textColor="#E5E7EB"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_chip_white_soft"
                            android:gravity="center"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="View biển • Hồ bơi"
                            android:textColor="#0F6CBD"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </FrameLayout>

                <!-- BRANCH RIVERSIDE -->
                <FrameLayout
                    android:id="@+id/cardBranchRiverside"
                    android:layout_width="match_parent"
                    android:layout_height="270dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_card_white_rounded"
                    android:clickable="true"
                    android:clipToOutline="true"
                    android:focusable="true"
                    android:outlineProvider="background">

                    <ImageView
                        android:id="@+id/imgBranchRiverside"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/branch_riverside" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_amenity_image_overlay" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="14dp"
                        android:background="@drawable/bg_chip_white_soft"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="Riverside"
                        android:textColor="#0F6CBD"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="ABC Riverside Premium"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="45 Bạch Đằng, Đà Nẵng"
                            android:textColor="#F8FAFC"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:lineSpacingExtra="2dp"
                            android:text="Chi nhánh ven sông với không gian yên tĩnh, view đẹp và dịch vụ cao cấp."
                            android:textColor="#E5E7EB"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_chip_white_soft"
                            android:gravity="center"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:text="View sông • Yên tĩnh"
                            android:textColor="#0F6CBD"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </FrameLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <include layout="@layout/layout_bottom_nav_user" />

</FrameLayout>