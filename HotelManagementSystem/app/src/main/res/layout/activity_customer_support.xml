<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB">

    <ScrollView
        android:id="@+id/scrollCustomerSupport"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="105dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="185dp"
                android:background="@drawable/bg_home_header_blue"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingTop="52dp"
                android:paddingEnd="24dp"
                android:paddingBottom="18dp">

                <TextView
                    android:id="@+id/btnBackSupport"
                    android:layout_width="44dp"
                    android:layout_height="34dp"
                    android:gravity="center_vertical"
                    android:text="←"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Chăm sóc khách hàng"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="ABC Hotel luôn sẵn sàng hỗ trợ bạn 24/7."
                    android:textColor="#EAF6FF"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- CONTENT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- QUICK CONTACT -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_home_card"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Liên hệ nhanh"
                        android:textColor="#111827"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Hotline: 0123 456 789"
                        android:textColor="#21A8F3"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Email: support@abchotel.vn"
                        android:textColor="#4B5563"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Địa chỉ: 12 Nguyễn Huệ, Quận 1, TP.HCM"
                        android:textColor="#4B5563"
                        android:textSize="14sp" />

                </LinearLayout>

                <!-- FAQ -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="FAQ"
                    android:textColor="#111827"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_home_card"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1. Tôi có thể check-in lúc mấy giờ?"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Quý khách có thể check-in từ 14:00 và check-out trước 12:00."
                        android:textColor="#6B7280"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="2. Tôi có thể hủy booking không?"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Bạn có thể hủy booking trong mục Booking của tôi trước ngày nhận phòng."
                        android:textColor="#6B7280"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="3. Tôi có nhận được ưu đãi thành viên không?"
                        android:textColor="#111827"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Thành viên Gold được giảm giá, tích điểm và nhận thông báo ưu đãi sớm."
                        android:textColor="#6B7280"
                        android:textSize="14sp" />

                </LinearLayout>

                <!-- FORM -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Gửi yêu cầu hỗ trợ"
                    android:textColor="#111827"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_home_card"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <EditText
                        android:id="@+id/edtSupportName"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:background="@drawable/bg_input"
                        android:hint="Họ tên"
                        android:inputType="textPersonName"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/edtSupportPhone"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_input"
                        android:hint="Số điện thoại"
                        android:inputType="phone"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/edtSupportContent"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_input"
                        android:gravity="top"
                        android:hint="Bạn cần hỗ trợ vấn đề gì?"
                        android:inputType="textMultiLine"
                        android:padding="14dp"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF"
                        android:textSize="14sp" />

                    <Button
                        android:id="@+id/btnSubmitSupport"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="18dp"
                        android:background="@drawable/bg_button_primary"
                        android:backgroundTint="@null"
                        android:text="Gửi yêu cầu"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <include layout="@layout/layout_bottom_nav_user" />

</FrameLayout>