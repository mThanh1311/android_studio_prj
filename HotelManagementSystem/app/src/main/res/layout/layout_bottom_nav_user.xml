<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bottomNav"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:layout_gravity="bottom"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_bottom_nav"
    android:elevation="8dp"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingStart="6dp"
    android:paddingEnd="6dp">

    <!-- HOME -->
    <LinearLayout
        android:id="@+id/navHome"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/iconNavHome"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_home_outline"
            android:tint="#6B7280" />

        <TextView
            android:id="@+id/textNavHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Home"
            android:textColor="#6B7280"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- BOOKING -->
    <LinearLayout
        android:id="@+id/navBookings"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/iconNavBooking"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_calendar_outline"
            android:tint="#6B7280" />

        <TextView
            android:id="@+id/textNavBooking"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Booking"
            android:textColor="#6B7280"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- NOTIFICATION -->
    <FrameLayout
        android:id="@+id/navNotificationContainer"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/navNotifications"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/iconNavNotification"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_notifications_outline"
                android:tint="#6B7280" />

            <TextView
                android:id="@+id/textNavNotification"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Thông báo"
                android:textColor="#6B7280"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvNotificationBadge"
            android:layout_width="19dp"
            android:layout_height="19dp"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginStart="18dp"
            android:layout_marginTop="8dp"
            android:background="#EF4444"
            android:gravity="center"
            android:text="1"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:visibility="gone" />
    </FrameLayout>

    <!-- PROFILE -->
    <LinearLayout
        android:id="@+id/navProfile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/iconNavProfile"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_person_outline"
            android:tint="#6B7280" />

        <TextView
            android:id="@+id/textNavProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Profile"
            android:textColor="#6B7280"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- SETTING -->
    <LinearLayout
        android:id="@+id/navSettings"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/iconNavSettings"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_settings_outline"
            android:tint="#6B7280" />

        <TextView
            android:id="@+id/textNavSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Setting"
            android:textColor="#6B7280"
            android:textSize="11sp" />
    </LinearLayout>

</LinearLayout>